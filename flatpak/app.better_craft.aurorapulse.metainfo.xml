<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.better_craft.aurorapulse</id>
  <name>Aurora Pulse</name>
  <summary>Local-first music player with DLNA streaming</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <update_contact>support_AT_better-craft.app</update_contact>

  <developer id="app.better_craft">
    <name>better_craft</name>
  </developer>

  <description>
    <p>
      Aurora Pulse is a beautifully crafted, local-first music player that puts your
      personal music library front and center. It supports a wide range of audio formats
      including FLAC, MP3, AAC, OGG, WAV and more.
    </p>
    <p>Features:</p>
    <ul>
      <li>Local library management with automatic metadata and embedded cover art</li>
      <li>DLNA/UPnP streaming to network renderers (speakers, AVRs, smart TVs)</li>
      <li>Podcast discovery, subscriptions and downloads</li>
      <li>Gapless playback and crossfade</li>
      <li>CD ripping and Digital Audio Player (DAP) synchronization</li>
      <li>MPRIS integration for desktop media keys</li>
      <li>Light and dark themes, fully keyboard navigable</li>
    </ul>
    <p>
      Aurora Pulse is local-first: your library, listening history and settings stay on
      your device. No account required, no telemetry.
    </p>
  </description>

  <launchable type="desktop-id">app.better_craft.aurorapulse.desktop</launchable>

  <icon type="stock">app.better_craft.aurorapulse</icon>

