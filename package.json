{
  "name": "aurora",
  "productName": "Aurora",
  "version": "1.3.1",
  "description": "A cross-platform music player built with Electron",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:main": "cross-env NODE_ENV=production webpack --config ./.erb/configs/webpack.config.main.prod.babel.js",
    "build:renderer": "cross-env NODE_ENV=production webpack --config ./.erb/configs/webpack.config.renderer.prod.babel.js",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir src",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci:check": "npm run lint && npm run typecheck",
    "package": "rimraf src/dist && npm run build && node ./.erb/scripts/Package.js",
    "package:mac": "npm run package -- --mac --c.mac.identity=null",
    "package:win": "npm run package -- --win",
    "postinstall": "node -r @babel/register .erb/scripts/CheckNativeDep.js && electron-builder install-app-deps && cross-env NODE_ENV=development webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.babel.js && opencollective-postinstall && yarn-deduplicate yarn.lock",
    "start": "node -r @babel/register ./.erb/scripts/CheckPortInUse.js && npm run start:renderer",
    "start:debug": "cross-env PORT=1213 node -r @babel/register ./.erb/scripts/CheckPortInUse.js && cross-env PORT=1213 npm run start:renderer:debug",
    "start:renderer": "cross-env NODE_ENV=development webpack serve --config ./.erb/configs/webpack.config.renderer.dev.babel.js",
    "start:renderer:debug": "cross-env START_MAIN_CMD=start:main:debug NODE_ENV=development webpack serve --config ./.erb/configs/webpack.config.renderer.dev.babel.js",
    "start:main": "webpack --config ./.erb/configs/webpack.config.main.dev.babel.js && cross-env DEBUG=aurora:*,-aurora:module:ipc:main electron ./src/main.dev.js",
    "start:main:debug": "webpack --config ./.erb/configs/webpack.config.main.dev.babel.js && cross-env DEBUG=aurora:*,-aurora:module:ipc:main electron --inspect=5858 ./src/main.dev.js",
    "test": "jest",
    "test:ci": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --runInBand"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ]
  },
  "build": {
    "productName": "Aurora",
    "appId": "com.bbbneo333.aurora",
    "artifactName": "${productName}-${os}-${arch}-${version}.${ext}",
    "files": [
      "dist/**",
      "node_modules/**",
      "index.html",
      "main.prod.js",
      "main.prod.js.map",
      "package.json",
      "assets/**",
      "!**/*.md",
      "!**/*.map"
    ],
    "afterSign": ".erb/scripts/Notarize.js",
    "mac": {
      "executableName": "Aurora",
      "target": [
        "dmg",
        "zip"
      ],
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "icon": "assets/icons/icon.icns"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "assets/icons"
    },
    "directories": {
      "app": "src",
      "buildResources": "assets",
      "output": "release"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "bbbneo333",
      "repo": "aurora",
      "private": false
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "assets/icons/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbbneo333/aurora.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bbbneo333/aurora/issues"
  },
  "homepage": "https://github.com/bbbneo333/aurora",
